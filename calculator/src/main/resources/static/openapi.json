            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Отказ по правилам скоринга (например, недостаточный возраст или стаж)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LoanStatementRequestDto": {
        "type": "object",
        "required": [
          "amount",
          "term",
          "firstName",
          "lastName",
          "email",
          "birthday",
          "passportSeries",
          "passportNumber"
        ],
        "properties": {
          "amount": {
            "type": "number",
            "minimum": 20000,
            "description": "Запрашиваемая сумма кредита",
            "example": 100000
          },
          "term": {
            "type": "integer",
            "minimum": 6,
            "description": "Срок кредита в месяцах",
            "example": 12
          },
          "firstName": {
            "type": "string",
            "minLength": 2,
            "maxLength": 30,
            "description": "Имя клиента",
            "example": "Ivan"
          },
          "lastName": {
            "type": "string",
            "minLength": 2,
            "maxLength": 30,
            "description": "Фамилия клиента",
            "example": "Ivanov"
          },
          "middleName": {
            "type": "string",
            "minLength": 2,
            "maxLength": 30,
            "description": "Отчество клиента (при наличии)",
            "example": "Ivanovich"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Электронная почта",
            "example": "ivan@example.com"
          },
          "birthday": {
            "type": "string",
            "format": "date",
            "description": "Дата рождения",
            "example": "1990-01-01"
          },
          "passportSeries": {
            "type": "string",
            "pattern": "^\\d{4}$",
            "description": "Серия паспорта",
            "example": "1234"
          },
          "passportNumber": {
            "type": "string",
            "pattern": "^\\d{6}$",
            "description": "Номер паспорта",
            "example": "123456"
          }
        }
      },
      "LoanOfferDto": {
        "type": "object",
        "properties": {
          "statementId": {
            "type": "string",
            "format": "uuid",
            "description": "Идентификатор заявки (возвращается null на этапе калькулятора)",
            "nullable": true
          },
          "requestedAmount": {
            "type": "number",
            "description": "Запрошенная сумма кредита",
            "example": 100000
          },
          "totalAmount": {
            "type": "number",
            "description": "Итоговая сумма кредита (с учетом страховки)",
            "example": 110000
          },
          "term": {
            "type": "integer",
            "description": "Срок кредита в месяцах",
            "example": 12
          },
          "monthlyPayment": {
            "type": "number",
            "description": "Ежемесячный аннуитетный платеж",
            "example": 9750.50
          },
          "rate": {
            "type": "number",
            "description": "Итоговая процентная ставка",
            "example": 11.0
          },
          "isInsuranceEnabled": {
            "type": "boolean",
            "description": "Включена ли страховка",
            "example": true
          },
          "isSalaryClient": {
            "type": "boolean",
            "description": "Является ли клиент зарплатным",
            "example": true
          }
        }
      },
      "ScoringDataDto": {
        "type": "object",
        "required": [
          "amount",
          "term",
          "firstName",
          "lastName",
          "gender",
          "birthdate",
          "passportSeries",
          "passportNumber",
          "passportIssueDate",
          "passportIssueBranch",
          "maritalStatus",
          "dependentAmount",
          "employment",
          "accountNumber",
          "isInsuranceEnabled",
          "isSalaryClient"
        ],
        "properties": {
          "amount": { "type": "number", "example": 100000 },
          "term": { "type": "integer", "example": 12 },
          "firstName": { "type": "string", "example": "Ivan" },
          "lastName": { "type": "string", "example": "Ivanov" },
          "middleName": { "type": "string", "example": "Ivanovich" },
          "gender": { "$ref": "#/components/schemas/Gender" },
          "birthdate": { "type": "string", "format": "date", "example": "1990-01-01" },
          "passportSeries": { "type": "string", "example": "1234" },
          "passportNumber": { "type": "string", "example": "123456" },
          "passportIssueDate": { "type": "string", "format": "date", "example": "2010-05-15" },
          "passportIssueBranch": { "type": "string", "example": "ОВД г. Москвы" },
          "maritalStatus": { "$ref": "#/components/schemas/MaritalStatus" },
          "dependentAmount": { "type": "integer", "example": 0 },
          "employment": { "$ref": "#/components/schemas/EmploymentDto" },
          "accountNumber": { "type": "string", "example": "40817810099910004312" },
          "isInsuranceEnabled": { "type": "boolean", "example": true },
          "isSalaryClient": { "type": "boolean", "example": true }
        }
      },
      "EmploymentDto": {
        "type": "object",
        "properties": {
          "employmentStatus": { "$ref": "#/components/schemas/EmploymentStatus" },
          "employerINN": { "type": "string", "example": "772816897112" },
          "salary": { "type": "number", "example": 100000 },
          "position": { "$ref": "#/components/schemas/Position" },
          "workExperienceTotal": { "type": "integer", "example": 60 },
          "workExperienceCurrent": { "type": "integer", "example": 24 }
        }
      },
      "CreditDto": {
        "type": "object",
        "properties": {
          "amount": { "type": "number", "example": 110000 },
          "term": { "type": "integer", "example": 12 },
          "monthlyPayment": { "type": "number", "example": 9750.50 },
          "rate": { "type": "number", "example": 11.0 },
          "psk": { "type": "number", "example": 11.55 },
          "isInsuranceEnabled": { "type": "boolean", "example": true },
          "isSalaryClient": { "type": "boolean", "example": true },
          "paymentSchedule": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PaymentScheduleElementDto" }
          }
        }
      },
      "PaymentScheduleElementDto": {
        "type": "object",
        "properties": {
          "number": { "type": "integer", "example": 1 },
          "date": { "type": "string", "format": "date", "example": "2023-11-27" },
          "totalPayment": { "type": "number", "example": 9750.50 },
          "interestPayment": { "type": "number", "example": 1008.33 },
          "debtPayment": { "type": "number", "example": 8742.17 },
          "remainingDebt": { "type": "number", "example": 101257.83 }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "status": { "type": "integer", "example": 400 },
          "error": { "type": "string", "example": "Validation Failed" },
          "message": { "type": "string", "example": "amount: Сумма кредита должна быть больше или равна 20000;" }
        }
      },
      "Gender": {
        "type": "string",
        "enum": ["MALE", "FEMALE", "NON_BINARY"]
      },
      "MaritalStatus": {
        "type": "string",
        "enum": ["MARRIED", "DIVORCED", "SINGLE", "WIDOW_WIDOWER"]
      },
      "EmploymentStatus": {
        "type": "string",
        "enum": ["UNEMPLOYED", "SELF_EMPLOYED", "EMPLOYED", "BUSINESS_OWNER"]
      },
      "Position": {
        "type": "string",
        "enum": ["WORKER", "MID_MANAGER", "TOP_MANAGER", "OWNER"]
      }
    }
  }
}